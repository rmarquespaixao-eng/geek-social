# Variáveis opcionais lidas pelo docker-compose.yml da raiz.
# Copie pra .env e edite só o que quiser sobrescrever.
# Os defaults do compose já bastam pra rodar localmente em modo alpha.

# ─── Portas expostas no host ──────────────────────────────────────────────
API_PORT=3000
FRONTEND_PORT=8080
DOCS_PORT=3030
POSTGRES_PORT=5432
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
REDIS_PORT=6379

# ─── Postgres ─────────────────────────────────────────────────────────────
POSTGRES_USER=dev
POSTGRES_PASSWORD=dev
POSTGRES_DB=geek_social

# ─── MinIO (S3 local) ─────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_BUCKET_NAME=geek-social-media

# ─── API ──────────────────────────────────────────────────────────────────
# Em produção: gere um valor aleatório com `openssl rand -hex 32`
JWT_SECRET=dev-only-secret-change-me-in-production-please-32
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=7
SES_FROM_EMAIL=noreply@geek-social.local
AWS_REGION=us-east-1

# Web Push (VAPID) — gere com: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT=dev@geek-social.local

# Google OAuth (opcional)
GOOGLE_OAUTH_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Hardening (auditoria #3, #4, #5) ─────────────────────────────────────
# TRUST_PROXY: 'false' (default) | 'true' | número de hops | CIDR(s) separados por vírgula.
# Em prod atrás de proxy reverso (nginx/cloudflare), configure conforme topologia.
TRUST_PROXY=false
