# Banco de dados
DATABASE_URL=postgresql://dev:dev@localhost:5432/geek_social

# JWT
JWT_SECRET=troque-por-um-secret-longo-e-aleatorio
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=7

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=geek-social-media

# Storage S3-compatível (opcional — use pra MinIO/R2/etc; deixe vazio pra usar S3 padrão)
STORAGE_ENDPOINT=
STORAGE_PUBLIC_URL=

# E-mail
SES_FROM_EMAIL=noreply@seudominio.com

# Web Push (VAPID) — gere com: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT=mailto:contato@seudominio.com

# App
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# Keycloak (desabilitado por padrão)
KEYCLOAK_ENABLED=false
KEYCLOAK_URL=
KEYCLOAK_REALM=
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=

# Google OAuth (login social)
# 1. Crie credenciais em https://console.cloud.google.com/apis/credentials
# 2. Tipo "Web application"
# 3. Authorized redirect URI: ${APP_URL}/auth/google/callback
GOOGLE_OAUTH_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Steam — só requer JOBS_DATABASE_URL no servidor; cada usuário informa a própria Web API key no perfil
# (criar banco aux manualmente: CREATE DATABASE geek_social_jobs;)
JOBS_DATABASE_URL=postgresql://dev:dev@localhost:5432/geek_social_jobs
