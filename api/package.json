  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && cp -r src/shared/infra/database/migrations dist/shared/infra/database/migrations",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --project e2e",
    "test:all": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "export:openapi": "tsx scripts/export-openapi.ts",
    "export:dbml": "tsx scripts/export-dbml.ts",
    "export:all": "npm run export:openapi && npm run export:dbml"
  },
  "keywords": [],
