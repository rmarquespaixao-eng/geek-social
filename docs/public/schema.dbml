enum collection_type {
  games
  books
  cardgames
  boardgames
  custom
}

enum collection_visibility {
  public
  private
  friends_only
}

enum conversation_type {
  dm
  group
}

enum dm_request_status {
  pending
  accepted
  rejected
}

enum field_type {
  text
  number
  date
  boolean
  select
  money
}

enum friendship_status {
  pending
  accepted
}

enum item_availability {
  none
  sale
  trade
  both
}

enum listing_status {
  active
  paused
  closed
}

enum member_role {
  owner
  admin
  member
}

enum notification_type {
  friend_request
  friend_accepted
  post_comment
  post_reaction
  steam_import_done
  steam_import_partial
  offer_received
  offer_accepted
  offer_rejected
  offer_completed
  offer_cancelled
  offer_expired
  dm_request_received
  rating_received
  counter_proposal_received
  proposal_rejected
}

enum offer_status {
  pending
  accepted
  rejected
  cancelled
  completed
}

enum offer_type {
  buy
  trade
}

enum post_type {
  manual
  item_share
}

enum post_visibility {
  public
  friends_only
  private
}

enum privacy {
  public
  friends_only
  private
}

enum proposal_status {
  pending
  accepted
  rejected
  superseded
}

enum reaction_type {
  power_up
  epic
  critical
  loot
  gg
}

enum report_reason {
  spam
  harassment
  nsfw
  hate
  other
}

enum report_status {
  pending
  reviewed
  dismissed
}

enum report_target_type {
  user
  message
  post
  collection
  conversation
}

table collection_field_schema {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  collection_id uuid [not null]
  field_definition_id uuid [not null]
  is_required boolean [not null, default: false]
  display_order integer [not null, default: 0]
}

table collections {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  user_id uuid [not null]
  name varchar(100) [not null]
  description text
  icon_url varchar
  cover_url varchar
  type collection_type [not null]
  visibility collection_visibility [not null, default: 'public']
  auto_share_to_feed boolean [not null, default: false]
  created_at "timestamp with time zone" [not null, default: `now()`]
  updated_at "timestamp with time zone" [not null, default: `now()`]
}

table conversation_members {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  conversation_id uuid [not null]
  user_id uuid [not null]
  role member_role [not null, default: 'member']
  permissions jsonb [not null, default: `{"can_send_messages":true,"can_send_files":true}`]
  joined_at "timestamp with time zone" [not null, default: `now()`]
  last_read_at "timestamp with time zone"
  is_archived boolean [not null, default: false]
  hidden_at "timestamp with time zone"
  is_muted boolean [not null, default: false]

  indexes {
    (conversation_id, user_id) [name: 'conversation_members_unique', unique]
  }
}

table conversations {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  type conversation_type [not null]
  name varchar(100)
  description text
  cover_url varchar
  created_by uuid
  is_temporary boolean [not null, default: false]
  created_at "timestamp with time zone" [not null, default: `now()`]
  updated_at "timestamp with time zone" [not null, default: `now()`]
}

table dm_requests {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  sender_id uuid [not null]
  receiver_id uuid [not null]
  status dm_request_status [not null, default: 'pending']
  conversation_id uuid
  created_at "timestamp with time zone" [not null, default: `now()`]
  updated_at "timestamp with time zone" [not null, default: `now()`]

  indexes {
    (sender_id, receiver_id) [name: 'dm_requests_unique', unique]
  }
}

table field_definitions {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  user_id uuid
  name varchar(100) [not null]
  field_key varchar(50) [not null]
  field_type field_type [not null]
  collection_type collection_type
  select_options jsonb
  is_system boolean [not null, default: false]
  is_hidden boolean [not null, default: false]
  created_at "timestamp with time zone" [not null, default: `now()`]
}

table friendships {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  requester_id uuid [not null]
  receiver_id uuid [not null]
  status friendship_status [not null, default: 'pending']
  created_at "timestamp with time zone" [not null, default: `now()`]
  updated_at "timestamp with time zone" [not null, default: `now()`]

  indexes {
    (requester_id, receiver_id) [name: 'friendships_requester_receiver_unique', unique]
  }
}

table import_batch_finalized {
  batch_id uuid [pk, not null]
  user_id uuid [not null]
  collection_id uuid [not null]
  total integer [not null]
  imported integer [not null]
  updated integer [not null]
  failed integer [not null]
  finalized_at "timestamp with time zone" [not null, default: `now()`]

  indexes {
    (user_id, finalized_at) [name: 'import_batch_finalized_user_idx']
  }
}

table item_offers {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  type offer_type [not null]
  item_id uuid [not null]
  owner_id uuid [not null]
  offerer_id uuid [not null]
  offered_item_id uuid
  offered_price "numeric(12, 2)"
  message text
  status offer_status [not null, default: 'pending']
  offerer_confirmed_at "timestamp with time zone"
  owner_confirmed_at "timestamp with time zone"
  listing_id uuid
  created_at "timestamp with time zone" [not null, default: `now()`]
  updated_at "timestamp with time zone" [not null, default: `now()`]

  indexes {
    (item_id, offerer_id) [name: 'item_offers_pending_unique', unique]
    (owner_id, status, created_at) [name: 'item_offers_owner_status_idx']
    (offerer_id, status, created_at) [name: 'item_offers_offerer_status_idx']
    listing_id [name: 'item_offers_listing_idx']
  }
}

table items {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  collection_id uuid [not null]
  name varchar(200) [not null]
  cover_url varchar
  fields jsonb [not null, default: `{}`]
  rating smallint
  comment text
  created_at "timestamp with time zone" [not null, default: `now()`]
  updated_at "timestamp with time zone" [not null, default: `now()`]
}

table listing_ratings {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  offer_id uuid [not null]
  rater_id uuid [not null]
  ratee_id uuid [not null]
  score smallint [not null]
  created_at "timestamp with time zone" [not null, default: `now()`]
  updated_at "timestamp with time zone" [not null, default: `now()`]

  indexes {
    (offer_id, rater_id) [name: 'listing_ratings_offer_rater_uniq', unique]
    ratee_id [name: 'listing_ratings_ratee_idx']
    offer_id [name: 'listing_ratings_offer_idx']
  }
}

table listings {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  item_id uuid [not null]
  owner_id uuid [not null]
  availability item_availability [not null]
  asking_price "numeric(10, 2)"
  payment_methods text[] [not null, default: `[]`]
  status listing_status [not null, default: 'active']
  disclaimer_accepted_at "timestamp with time zone" [not null]
  created_at "timestamp with time zone" [not null, default: `now()`]
  updated_at "timestamp with time zone" [not null, default: `now()`]

  indexes {
    item_id [name: 'listings_item_active_uniq', unique]
    (owner_id, status, created_at) [name: 'listings_owner_status_idx']
    updated_at [name: 'listings_active_updated_idx']
  }
}

table message_attachments {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  message_id uuid
  uploaded_by uuid [not null]
  url text [not null]
  filename text [not null]
  mime_type text [not null]
  size_bytes integer [not null]
  display_order integer [not null, default: 0]
  duration_ms integer
  waveform_peaks jsonb
  thumbnail_url text
}

table message_reactions {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  message_id uuid [not null]
  user_id uuid [not null]
  emoji varchar(16) [not null]
  created_at "timestamp with time zone" [not null, default: `now()`]

  indexes {
    (message_id, user_id, emoji) [name: 'message_reactions_unique', unique]
    message_id [name: 'message_reactions_message_idx']
  }
}

table messages {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  conversation_id uuid [not null]
  user_id uuid [not null]
  content text
  reply_to_id uuid
  call_metadata jsonb
  is_temporary boolean [not null, default: false]
  temporary_event jsonb
  hidden_for_user_ids jsonb [not null, default: `[]`]
  deleted_at "timestamp with time zone"
  created_at "timestamp with time zone" [not null, default: `now()`]
  updated_at "timestamp with time zone" [not null, default: `now()`]

  indexes {
    (conversation_id, created_at) [name: 'messages_conversation_created_at_idx']
  }
}

table notifications {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  recipient_id uuid [not null]
  actor_id uuid [not null]
  type notification_type [not null]
  entity_id uuid
  read boolean [not null, default: false]
  created_at "timestamp with time zone" [not null, default: `now()`]

  indexes {
    (recipient_id, created_at) [name: 'notifications_recipient_created_at_idx']
  }
}

table offer_proposals {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  offer_id uuid [not null]
  proposer_id uuid [not null]
  offered_price "numeric(12, 2)"
  offered_item_id uuid
  message text
  status proposal_status [not null, default: 'pending']
  created_at "timestamp with time zone" [not null, default: `now()`]
  updated_at "timestamp with time zone" [not null, default: `now()`]

  indexes {
    (offer_id, created_at) [name: 'offer_proposals_offer_idx']
    offer_id [name: 'offer_proposals_one_pending_uniq', unique]
  }
}

table password_reset_tokens {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  user_id uuid [not null]
  token_hash varchar [not null]
  expires_at "timestamp with time zone" [not null]
  used_at "timestamp with time zone"
}

table post_comments {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  post_id uuid [not null]
  user_id uuid [not null]
  content text [not null]
  created_at "timestamp with time zone" [not null, default: `now()`]
  updated_at "timestamp with time zone" [not null, default: `now()`]

  indexes {
    (post_id, created_at) [name: 'post_comments_post_created_at_idx']
  }
}

table post_media {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  post_id uuid [not null]
  url text [not null]
  thumbnail_url text
  display_order integer [not null]

  indexes {
    post_id [name: 'post_media_post_id_idx']
  }
}

table post_reactions {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  post_id uuid [not null]
  user_id uuid [not null]
  type reaction_type [not null]
  created_at "timestamp with time zone" [not null, default: `now()`]

  indexes {
    (post_id, user_id) [name: 'post_reactions_post_user_unique', unique]
  }
}

table posts {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  user_id uuid [not null]
  type post_type [not null]
  content text
  visibility post_visibility [not null]
  item_id uuid
  collection_id uuid
  created_at "timestamp with time zone" [not null, default: `now()`]
  updated_at "timestamp with time zone" [not null, default: `now()`]

  indexes {
    (user_id, created_at) [name: 'posts_user_created_at_idx']
    (visibility, created_at) [name: 'posts_visibility_created_at_idx']
    item_id [name: 'posts_item_id_idx']
  }
}

table push_subscriptions {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  user_id uuid [not null]
  endpoint text [not null]
  p256dh text [not null]
  auth text [not null]
  created_at "timestamp with time zone" [not null, default: `now()`]

  indexes {
    endpoint [name: 'push_subscriptions_endpoint_unique', unique]
  }
}

table refresh_tokens {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  user_id uuid [not null]
  token_hash varchar [not null]
  expires_at "timestamp with time zone" [not null]
  created_at "timestamp with time zone" [not null, default: `now()`]
}

table reports {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  reporter_id uuid [not null]
  target_type report_target_type [not null]
  target_id uuid [not null]
  reason report_reason [not null]
  description text
  status report_status [not null, default: 'pending']
  created_at "timestamp with time zone" [not null, default: `now()`]
  updated_at "timestamp with time zone" [not null, default: `now()`]

  indexes {
    (reporter_id, target_type, target_id) [name: 'reports_reporter_target_unique', unique]
    (status, created_at) [name: 'reports_status_created_at_idx']
  }
}

table user_blocks {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  blocker_id uuid [not null]
  blocked_id uuid [not null]
  created_at "timestamp with time zone" [not null, default: `now()`]

  indexes {
    (blocker_id, blocked_id) [name: 'user_blocks_blocker_blocked_unique', unique]
  }
}

table user_presence {
  user_id uuid [pk, not null]
  last_seen_at "timestamp with time zone" [not null]
  updated_at "timestamp with time zone" [not null, default: `now()`]
}

table users {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  email varchar(255) [not null, unique]
  password_hash varchar
  display_name varchar(100) [not null]
  bio text
  avatar_url varchar
  cover_url varchar
  cover_color varchar(7)
  profile_background_url varchar
  profile_background_color varchar(7)
  privacy privacy [not null, default: 'public']
  email_verified boolean [not null, default: false]
  show_presence boolean [not null, default: true]
  show_read_receipts boolean [not null, default: true]
  steam_id varchar(20) [unique]
  steam_linked_at "timestamp with time zone"
  steam_api_key varchar(32)
  google_id varchar(64) [unique]
  google_linked_at "timestamp with time zone"
  birthday date
  interests jsonb [not null, default: `[]`]
  pronouns varchar(50)
  location varchar(120)
  website varchar(255)
  created_at "timestamp with time zone" [not null, default: `now()`]
  updated_at "timestamp with time zone" [not null, default: `now()`]
}